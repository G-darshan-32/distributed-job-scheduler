# Database
POSTGRES_USER=djs_user
POSTGRES_PASSWORD=djs_password
POSTGRES_DB=djs_db
DATABASE_URL=postgresql://djs_user:djs_password@localhost:5432/djs_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_in_production_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=15000
WORKER_STALE_THRESHOLD_MS=60000

# Frontend
VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=ws://localhost:4000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# AI (Optional - for failure summaries)
OPENAI_API_KEY=
